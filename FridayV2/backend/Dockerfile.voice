FROM python:3.14-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libportaudio2 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN chmod +x startup-voice.sh

# Starts a health server on $PORT (Cloud Run requirement) then runs the LiveKit agent
CMD ["/bin/bash", "startup-voice.sh"]
